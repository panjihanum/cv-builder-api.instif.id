# Backend env — copy to .env dan isi. DO NOT commit real .env files.
# docker-compose.yml membaca file ini lewat env_file.
#
# Konfigurasi yang sering berubah (Duitku, Anthropic API key & model, isi pesan
# WhatsApp, rekening, harga) TIDAK ada di sini — semuanya diatur dari DASHBOARD
# ADMIN dan disimpan TERENKRIPSI di DB, supaya tidak perlu sentuh server.
#
# Yang tersisa di file ini adalah yang tidak bisa hidup di DB: kredensial infra,
# secret untuk mendekripsi DB itu sendiri, dan URL/kunci antar-service.
#
# DATABASE_URL, JWT_SECRET, dan ENCRYPTION_KEY divalidasi zod saat boot
# (src/lib/env.ts) — kalau salah satu hilang, proses langsung mati.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cv_builder?schema=public"
JWT_SECRET="change-me"
PORT=3011
CORS_ORIGIN="http://localhost:3010"

# Satu-satunya secret enkripsi (32 byte, base64).
# Generate: node -e "console.log('base64:'+require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="base64:GENERATE_32_BYTE_KEY"

# SSO admin dari hub instif.id — HARUS sama dengan SSO_SECRET di instif.id.
# Kosongkan untuk menonaktifkan SSO.
SSO_SECRET=""

# URL hub instif.id (dipakai hubSettings & payment/hub service).
INSTIF_HUB_URL="https://instif.id"

# Kunci bersama untuk endpoint stats/moderasi di instif.id.
# HARUS sama dengan ADMIN_STATS_KEY di repo instif.id.
ADMIN_STATS_KEY=""

# ── URL publik ──────────────────────────────────────────────────────────────
# PUBLIC_API_URL dipakai untuk membangun link approve/reject di notifikasi
# WhatsApp. Kalau kosong, link yang terkirim rusak (base-nya string kosong)
# tanpa error apa pun — isi di production.
PUBLIC_API_URL=""
# URL app publik untuk redirect setelah pembayaran. Kalau kosong, jatuh ke
# entri pertama CORS_ORIGIN.
PUBLIC_APP_URL=""

# ── WhatsApp ────────────────────────────────────────────────────────────────
# Gateway tunggal:
WA_GATEWAY_URL=""
WA_GATEWAY_SECRET=""
# Atau beberapa gateway dengan failover (menimpa dua var di atas).
# Format: "url1|secret1,url2|secret2"
WA_GATEWAYS=""
# Nomor tujuan notifikasi pembayaran. Kosong = notifikasi tidak dikirim.
NOTIFICATION_PHONE=""

# Menandatangani token approve/reject stateless. WAJIB diganti di production:
# ada default di source code, jadi kalau dibiarkan siapa pun bisa memalsukan
# token approve pembayaran.
QUICK_TOKEN_SECRET="change-this-secret-in-production"

# Direktori upload (foto & hasil export). Default "uploads", sudah dipetakan
# ke named volume cv_uploads di docker-compose.yml.
UPLOADS_DIR="uploads"
